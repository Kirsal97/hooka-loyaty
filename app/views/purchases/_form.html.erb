<div class="card shadow-sm mb-4">
  <div class="card-body">
    <h2 class="h6 text-uppercase text-muted mb-3">Add Purchase</h2>
    <%= form_with model: [client, Purchase.new], local: true do |f| %>
      <div class="mb-3">
        <%= f.label :note, class: "form-label small text-muted" %>
        <%= f.text_field :note, class: "form-control form-control-sm", placeholder: "Optional note" %>
      </div>
      <%= f.submit "Add Purchase", class: "btn btn-primary btn-sm" %>
    <% end %>
  </div>
</div>
