<%= turbo_frame_tag "search_results" do %>
  <% if query.present? %>
    <p class="text-muted small mb-2"><%= clients.size %> result<%= clients.size != 1 ? 's' : '' %> for "<%= query %>"</p>
  <% end %>
  <% if clients.any? %>
    <div class="list-group shadow-sm">
    <% clients.each do |client| %>
      <%= link_to "#", class: "list-group-item list-group-item-action" do %>
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <h6 class="mb-1"><%= client.name %></h6>
            <small class="text-muted">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16" class="me-1">
                <path d="M3.654 1.328a.678.678 0 0 0-1.015-.063L1.605 2.3c-.483.484-.661 1.169-.45 1.77a17.568 17.568 0 0 0 4.168 6.608 17.569 17.569 0 0 0 6.608 4.168c.601.211 1.286.033 1.77-.45l1.034-1.034a.678.678 0 0 0-.063-1.015l-2.307-1.794a.678.678 0 0 0-.58-.122l-2.19.547a1.745 1.745 0 0 1-1.657-.459L5.482 8.062a1.745 1.745 0 0 1-.46-1.657l.548-2.19a.678.678 0 0 0-.122-.58L3.654 1.328zM1.884.511a1.745 1.745 0 0 1 2.612.163L6.29 2.98c.329.423.445.974.315 1.494l-.547 2.19a.678.678 0 0 0 .178.643l2.457 2.457a.678.678 0 0 0 .644.178l2.189-.547a1.745 1.745 0 0 1 1.494.315l2.306 1.794c.829.645.905 1.87.163 2.611l-1.034 1.034c-.74.74-1.846 1.065-2.877.702a18.634 18.634 0 0 1-7.01-4.42 18.634 18.634 0 0 1-4.42-7.009c-.362-1.03-.037-2.137.703-2.877L1.885.511z"/>
              </svg>
              <%= client.phone %>
            </small>
          </div>
          <div class="text-end">
            <% if client.can_claim_reward? %>
              <span class="badge bg-success mb-1">
                <%= client.available_rewards %> reward<%= client.available_rewards > 1 ? 's' : '' %> available!
              </span>
            <% end %>
            <div class="small text-muted">
              Progress: <%= client.progress_to_next_reward %>/<%= Setting.reward_threshold %>
            </div>
            <div class="progress" style="height: 6px; width: 100px;">
              <% progress_percent = (client.progress_to_next_reward.to_f / Setting.reward_threshold * 100).round %>
              <div class="progress-bar" role="progressbar" style="width: <%= progress_percent %>%"></div>
            </div>
          </div>
        </div>
      <% end %>
    <% end %>
    </div>
  <% else %>
    <div class="text-center py-5 text-muted">
      <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" viewBox="0 0 16 16" class="mb-3">
        <path d="M7 14s-1 0-1-1 1-4 5-4 5 3 5 4-1 1-1 1H7zm4-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6z"/>
        <path fill-rule="evenodd" d="M5.216 14A2.238 2.238 0 0 1 5 13c0-1.355.68-2.75 1.936-3.72A6.325 6.325 0 0 0 5 9c-4 0-5 3-5 4s1 1 1 1h4.216z"/>
        <path d="M4.5 8a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5z"/>
      </svg>
      <% if query.present? %>
        <p>No clients found matching "<strong><%= query %></strong>"</p>
        <%= link_to "Add New Client", "#", class: "btn btn-primary" %>
      <% else %>
        <p>No recent clients yet</p>
        <p class="small">Search for a client or add a new one to get started.</p>
      <% end %>
    </div>
  <% end %>
<% end %>
