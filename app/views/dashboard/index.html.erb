<% content_for(:title) { Setting.lounge_name } %>

<div class="row justify-content-center">
  <div class="col-lg-8">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h1 class="h3 mb-0"><%= Setting.lounge_name %></h1>
    </div>

    <!-- Search Form -->
    <div class="card shadow-sm mb-4" data-controller="search">
      <div class="card-body">
        <%= form_with url: root_path, method: :get, data: { turbo_frame: "search_results", search_target: "form" } do |form| %>
          <div class="input-group input-group-lg">
            <%= form.telephone_field :phone,
                value: @query,
                class: "form-control",
                placeholder: t("dashboard.search_placeholder"),
                autofocus: true,
                autocomplete: "off",
                data: { search_target: "input", action: "input->search#search keydown->search#submitNow" } %>
            <button type="submit" class="btn btn-primary">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"/>
              </svg>
              <%= t("dashboard.search_button") %>
            </button>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Results Header -->
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h2 class="h5 mb-0"><%= t("dashboard.clients_header") %></h2>
      <%= link_to t("dashboard.add_new_client"), new_client_path, class: "btn btn-success btn-sm" %>
    </div>

    <!-- Client List (Turbo Frame for live search) -->
    <%= render "search_results", clients: @clients, query: @query %>
  </div>
</div>
