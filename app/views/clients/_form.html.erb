<%= form_with model: client do |form| %>
  <% if client.errors.any? %>
    <div class="alert alert-danger">
      <p class="mb-1"><strong>Please fix the errors below:</strong></p>
      <ul class="mb-0">
        <% client.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= form.label :name, class: "form-label" %>
    <%= form.text_field :name, class: "form-control", required: true, autofocus: true %>
  </div>

  <div class="mb-3">
    <%= form.label :phone, class: "form-label" %>
    <%= form.telephone_field :phone, class: "form-control", required: true, autocomplete: "tel" %>
  </div>

  <div class="d-flex gap-2">
    <%= form.submit class: "btn btn-primary" %>
  </div>
<% end %>
